<%- include('partials/header') %>

    <main>
        <h1>
            <%= project.title %>
        </h1>
        <p>
            <%= project.description %>
        </p>
        <p>
            <strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric' , month: 'long' , day: 'numeric' })
                %>
        </p>
        <p>
            <strong>Location:</strong>
            <%= project.location %>
        </p>
        <p>
            <strong>Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>
        <p>
            <strong>Categories:</strong>
            <% categories.forEach(category=> { %>
                <a href="/category/<%= category.category_id %>">
                    <%= category.name %>
                </a>&nbsp;
                <% }) %>
        </p>
        <p>
            <a href="/edit-project/<%= project.project_id %>">Edit this project</a>
        </p>
        <p>
            <a href="/project/<%= project.project_id %>/assign-categories">Edit Categories</a>
        </p>
    </main>

    <%- include('partials/footer') %>